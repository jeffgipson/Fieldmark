# API proxied to Rails via vite.config.js (leave empty in dev)
VITE_API_BASE_URL=

# Cross-app links (optional — for error messages / future nav)
VITE_APP_URL=http://localhost:5173
VITE_WEBSITE_URL=http://localhost:5174
# After ./bin/setup-local-domains:
# VITE_APP_URL=http://app.fieldmark.local
# VITE_WEBSITE_URL=http://fieldmark.local
