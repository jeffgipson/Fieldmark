ANTHROPIC_API_KEY=your_key_here
# Do NOT set DATABASE_URL for local dev — it overrides database.yml for test too,
# and `bin/rails test` will truncate fieldmark_development. Use database.yml instead.
# DATABASE_URL=postgresql://localhost/fieldmark_development
JWT_SECRET_KEY=your_secret_here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://localhost:5177
FRONTEND_URL=http://localhost:5173

# Transactional email — templates and jobs run; nothing is sent until delivery is enabled.
MAILER_FROM=Fieldmark <noreply@fieldmark.app>
# MAILER_DELIVER=false
# Future SendGrid: SENDGRID_API_KEY=  (wire adapter later; key alone does not send yet)
# Optional SMTP instead of SendGrid:
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
DEMO_EMAIL=demo@fieldmark.app
DEMO_PASSWORD=password123
# Optional: county parcel outlines on the map (https://regrid.com/api)
# Trial/sandbox keys only return data in Regrid's 7 demo counties (e.g. Dallas TX ~32.83,-96.56).
# Missouri is not included on trial — use "Mark field" in the app, or a paid plan for MO parcels.
REGRID_API_KEY=

# Google Places address search on farm/field map (Maps JavaScript API + Places API)
GOOGLE_MAPS_API_KEY=

ADMIN_EMAIL=admin@fieldmark.app
ADMIN_PASSWORD=password123

# Billing (mock Stripe by default — set BILLING_MOCK=false when wiring real Stripe)
BILLING_MOCK=true
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_BASIC=
# STRIPE_PRICE_PRO=
