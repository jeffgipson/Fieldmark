# Fieldmark local development URLs
# Copy the relevant lines into each app's .env (see README "Running the stack").
#
# Custom local domains (fieldmark.local): run ./bin/setup-local-domains
# See config/local-domains.env and docs/LOCAL_DOMAINS.md
#
#   api/.env          → FRONTEND_URL, CORS_ORIGINS
#   client/.env       → VITE_WEBSITE_URL, VITE_ADMIN_URL
#   website/.env      → VITE_APP_URL, VITE_WEBSITE_URL, VITE_ADMIN_URL, VITE_API_URL
#   frontend/admin/.env → (API via Vite proxy; optional VITE_* for future links)

# Ports (default — keep in sync if you change vite.config.js)
FIELDMARK_API_URL=http://localhost:3000
FIELDMARK_WEBSITE_URL=http://localhost:5174
FIELDMARK_APP_URL=http://localhost:5173
FIELDMARK_ADMIN_URL=http://localhost:5175

# --- api/.env ---
# FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175

# --- website/.env ---
# VITE_APP_URL=http://localhost:5173
# VITE_WEBSITE_URL=http://localhost:5174
# VITE_ADMIN_URL=http://localhost:5175
# VITE_API_URL=http://localhost:3000

# --- client/.env ---
# VITE_WEBSITE_URL=http://localhost:5174
# VITE_ADMIN_URL=http://localhost:5175
