# Copy to config/cloudflare-pages.env and set your production URLs.
# Used by: ./bin/deploy-cloudflare-pages
#
# Rails API (Hatchbox or other host)
API_URL=https://api.fieldmark.app

# Public URLs after Cloudflare Pages deploy (custom domains or *.pages.dev)
WEBSITE_URL=https://fieldmark-website.pages.dev
APP_URL=https://fieldmark-app.pages.dev
ADMIN_URL=https://fieldmark-admin.pages.dev

# Cloudflare account (wrangler whoami — export as CLOUDFLARE_ACCOUNT_ID for wrangler 4.x)
# Jeff@recruiterswebsites.com example: 0bce4761eb1853a1b6e3d387bc578af9
CLOUDFLARE_ACCOUNT_ID=

# Optional: Google Maps on farm map (client only)
# VITE_GOOGLE_MAPS_API_KEY=
