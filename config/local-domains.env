# Fieldmark local custom domains (fieldmark.local)
# Applied by: ./bin/setup-local-domains

FIELDMARK_DOMAIN=fieldmark.local

FIELDMARK_WEBSITE_URL=http://fieldmark.local
FIELDMARK_APP_URL=http://app.fieldmark.local
FIELDMARK_API_URL=http://api.fieldmark.local
FIELDMARK_ADMIN_URL=http://admin.fieldmark.local

# api/.env
FRONTEND_URL=http://app.fieldmark.local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://fieldmark.local,http://www.fieldmark.local,http://app.fieldmark.local,http://api.fieldmark.local,http://admin.fieldmark.local

# website/.env
VITE_WEBSITE_URL=http://fieldmark.local
VITE_APP_URL=http://app.fieldmark.local
VITE_ADMIN_URL=http://admin.fieldmark.local
VITE_API_URL=http://api.fieldmark.local

# client/.env
VITE_WEBSITE_URL=http://fieldmark.local
VITE_ADMIN_URL=http://admin.fieldmark.local

# frontend/admin/.env
VITE_APP_URL=http://app.fieldmark.local
VITE_WEBSITE_URL=http://fieldmark.local
