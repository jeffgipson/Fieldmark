# Dev: leave VITE_API_BASE_URL empty to proxy /api → Rails (see vite.config.js)
VITE_API_BASE_URL=
VITE_APP_NAME=Fieldmark

# Cross-app links (public website on :5174, admin, API docs at /developer on website)
VITE_WEBSITE_URL=http://localhost:5174
VITE_ADMIN_URL=http://localhost:5175
# After ./bin/setup-local-domains:
# VITE_WEBSITE_URL=http://fieldmark.local
# VITE_ADMIN_URL=http://admin.fieldmark.local

# Google Places Autocomplete on farm/field map search (Places API + Maps JavaScript API)
# VITE_GOOGLE_MAPS_API_KEY=
