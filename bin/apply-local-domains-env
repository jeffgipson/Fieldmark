#!/usr/bin/env bash
# Merge config/local-domains.env into each app's .env (creates from .env.example if missing).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SOURCE="$ROOT/config/local-domains.env"

if [[ ! -f "$SOURCE" ]]; then
  echo "Missing $SOURCE" >&2
  exit 1
fi

set_or_append() {
  local file=$1
  local key=$2
  local value=$3
  if grep -q "^${key}=" "$file" 2>/dev/null; then
    if [[ "$(uname)" == "Darwin" ]]; then
      sed -i '' "s|^${key}=.*|${key}=${value}|" "$file"
    else
      sed -i "s|^${key}=.*|${key}=${value}|" "$file"
    fi
  else
    printf '\n%s=%s\n' "$key" "$value" >>"$file"
  fi
}

ensure_env() {
  local dir=$1
  local example="$ROOT/$dir/.env.example"
  local env="$ROOT/$dir/.env"
  if [[ ! -f "$env" && -f "$example" ]]; then
    cp "$example" "$env"
    echo "  Created $dir/.env from .env.example"
  fi
}

apply_file() {
  local target=$1
  shift
  local keys=("$@")
  local env="$ROOT/$target/.env"
  [[ -f "$env" ]] || return 0

  for key in "${keys[@]}"; do
    local value
    value=$(grep -E "^${key}=" "$SOURCE" | head -1 | cut -d= -f2-)
    [[ -n "$value" ]] || continue
    set_or_append "$env" "$key" "$value"
  done
  echo "  Updated $target/.env"
}

echo "Applying local domain env vars…"

ensure_env api
ensure_env client
ensure_env website
ensure_env frontend/admin

apply_file api FRONTEND_URL CORS_ORIGINS
apply_file client VITE_WEBSITE_URL VITE_ADMIN_URL
apply_file website VITE_WEBSITE_URL VITE_APP_URL VITE_ADMIN_URL VITE_API_URL
apply_file frontend/admin VITE_APP_URL VITE_WEBSITE_URL

echo "✓ Env files updated (localhost URLs kept in CORS for fallback)"
